%{\pi^* \left( {{a_t}|{s_t}} \right)} = \arg \mathop {\max }\limits_{{\pi\left( {{a_t}|{s_t}} \right)}}  J({\pi\left( {{a_t}|{s_t}} \right)})
%\label{eq45}.
%\end{equation}


%\begin{equation}
%J\left( {{\pi _t}} \right): = {E_{\tau \sim {\pi _t}}}\left[ {\sum\limits_{t = 0}^T {{\gamma ^{t - 1}}} r_t} \right]
%\label{eq41}
%\end{equation}


%\subsection{SAC framework}
%The SAC algorithm incorporates the policy entropy ${\cal H}\left( {{\pi _t}\left( { \cdot |{s_t}} \right)} \right) = {E_{{a_t}\sim{\pi _t}}}[\log {\pi _t}\left( {{a_t}|{s_t}} \right)]$ into the reward while maximizing the basic optimization objective $- F_2(t)$. The expected long-term discounted reward of the model becomes
%\begin{equation}
%J\left( {{\pi _t}} \right) = {E_{\left( {{s_t},{a_t}} \right)\sim{\rho _\pi }}}\left[ {\sum\limits_{t = 0}^T {{\gamma ^{t - 1}}} r_t + \beta {\cal H}\left( {{\pi _t}\left( { \cdot |{s_t}} \right)} \right)} \right]
%\label{eq42}
%\end{equation}

%Temperature $\beta$ is the weight of the policy entropy which tradeoffs the VEC server between the exploration of feasible policies and the maximization of optimization goals. With constantly changing rewards, using a fixed $\beta$ will destabilize the whole training, so there is a great necessity to adjust $\beta$ automatically during the training. Here the authors in \cite{27} construct an optimization problem with a policy entropy constraint, allowing the average policy entropy weight to be bounded, and yet the policy entropy weight to be variable in different states
%\begin{equation}
%\begin{aligned}
%&{\max _{{\pi _0}:T}} \; {E_{{\rho _\pi }}}\left[ {\sum\limits_{t = 0}^T {{\gamma ^{t - 1}}r} \left( {{s_t},{a_t}} \right)} \right]\\
%s.t. \; \; &{E_{\left( {{s_t},{a_t}} \right)\sim{\rho _\pi }}}\left[ { - log\left( {{\pi _t}\left( {{a_t}|{s_t}} \right)} \right)} \right] \ge \bar {\cal H}
%\end{aligned}
%\label{eq43}
%\end{equation}
%
%By setting the lower bound $\bar {\cal H} = dim({a_t})$ is intended to make the $\beta {\cal H}\left( {{\pi _t}\left( { \cdot |{s_t}} \right)} \right)$ in Eq. \eqref{eq42} as large as possible. When the optimal action has not yet been learned, increase $\beta$ to explore more space; Conversely, if the optimal policy has been obtained, then decrease $\beta$ to reduce exploration. The optimal temperature parameter $\beta _t^*$ for dynamic adjustment at time $t$ can be attained based on the Lagrangian

\subsubsection{Solution}
SAC is known for its stability and robustness, and SAC encourages exploration and maintains a more diverse range of actions. Thus it is essential in our model where the environment is complex with multiple types of tasks and communication technologies. Therefore, the SAC algorithm was chosen as the most appropriate method for optimizing the policy in our model. We formulate the expected long-term discount reward of the DRL framework under policy ${\pi\left( {{a_t}|{s_t}} \right)}$ according to the SAC algorithm,
\begin{equation}
J({\pi\left( {{a_t}|{s_t}} \right)}) = {E}\left[ {\sum\limits_{t = 0}^T {{\gamma ^{t - 1}}} r_t + \beta {\cal H}\left( {{\pi\left( {\cdot|{s_t}} \right)}} \right)} \right]
\label{eq40_1},
\end{equation}
where $\pi\left( {\cdot|{s_t}} \right)$ is the policy when all available actions are taken under $s_t$, $\gamma  \in \left[ {0,1} \right]$ is the discounting factor, ${\cal H}\left( {{\pi\left( {\cdot|{s_t}} \right)}} \right) = {E}\left[\log {\pi\left( {\cdot|{s_t}} \right)}\right]$ is the policy entropy, $\beta$ is the tradeoff weight of the policy entropy between exploring feasible policy and maximizing reward, which can be adjusted dynamically and formulated as follows,
\begin{equation}
\beta^ *  = \arg {\min _{{\beta}}}{E}\left[ { - {\alpha _t}log\pi^ *\left( {{a_t}|{s_t}} \right)  - {\beta}\overline {\cal H} } \right]
\label{eq44},
\end{equation}
where $\bar {\cal H} = dim({a_t})$, ${\pi^ *\left( {{a_t}|{s_t}} \right)}$ is the optimal policy under $a_t$ and $s_t$ to maximize $J({\pi\left( {{a_t}|{s_t}} \right)})$.




%Next, we will describe the training stage of the SAC to obtain the optimal policy, then introduce the testing stage to check the performance under the optimal policy.

%In this paper, we turn to the choice of the SAC algorithm for policy optimization.

%SAC incorporates entropy into the reward function to encourage exploration of the policy space. This is crucial in our scenario, where the task division and resource allocation can vary greatly, and a good policy needs to balance between exploiting known good actions and exploring new ones.

%In contrast, while DDPG is a powerful algorithm, it tends to be more sensitive to hyperparameters and may not explore the policy space as thoroughly as SAC due to its deterministic policy. The selection of the SAC algorithm is not arbitrary but is based on the specific characteristics and requirements of our model. As we have outlined, our model involves complex interactions between multiple tasks, subtasks, and communication technologies. The offloading strategy and resource allocation, which form the actions in our model, can vary greatly. Therefore, we need an algorithm that can efficiently explore this vast policy space and learn robust policies. Therefore, the SAC algorithm was chosen as the most appropriate method for optimizing the policy in our model.}

%\subsubsection{Training stage}
\paragraph{Training stage}
%\hl{In this paper, all the values in the state space and action space are continuous variables, and the general reinforcement learning methods are only capable of solving variables with discrete as well as low-dimensional variables. For control tasks in high-dimensional, continuous state and action spaces, neural networks are used to approximate the values of the variables in the space. The Soft-Actor-Critic(SAC) algorithm is a reinforcement learning algorithm suitable for solving continuous state and action spaces, which introduces policy entropy into the reward, maximizing the reward while encouraging the VEC server to explore more feasible policies. Therefore, SAC has better robustness, stronger generalization ability.}
The architecture of the SAC algorithm includes an actor network, two critic networks and two target critic networks, where all these networks are the deep neural network (DNN). Let $\phi$ be the parameters of the actor network, ${\psi_1}$ and ${\psi_2}$ be the parameters of the two critic networks, $\bar \psi_1$ and $\bar \psi_2$ be the parameters of the two target critic networks. The pseudocode of the training stage for the SAC algorithm is described in Algorithm 1.

\begin{algorithm}
 	\caption{Training stage for the SAC based framework}
 	\label{algorithm1}
 	\KwIn{$V$,$\gamma$, $\phi$, ${\psi_1}$, ${\psi_2}$, $\bar \psi_1$, $\bar \psi_2$, $\beta$ }
 	\KwOut{optimized $\phi^*$}
 	Randomly initialize the $\phi$, ${\psi_1}$, ${\psi_2}$, $\beta$\;
 	
 	Initialize target networks by $\bar \psi_1\leftarrow\psi_1$, $\bar \psi_2\leftarrow\psi_2$\;
 	Initialize replay experience buffer $\mathcal{R}$\;
 	\For{episode from $1$ to $K^{train}_{max}$ }
 	{
 		Initialize millimeter-wave channel coefficients $\zeta$\;
 		Reset simulation parameters for the system model\;
 		
 		\For{time slot $t$ from $0$ to $T^{train}_{max}$ }
 		{
 			Receive observation state $s_{t}$\;
 			Generate the CPU allocation policy and communication offloading policy  $a_{t}$ \;
			Execute action $a_{t}$, observe reward $r_t$ and new state $s_{t+1}$ from the system model\;
 			Store tuple $(s_{t},a_{t},r_{t},s_{t+1})$ in $\mathcal{R}$\;
 			\If {episdoe $k$ can be exactly divided by $K_{u}$ }
 			{
 				
 				\For{iteration $r$ from $1$ to $R_{u}$ }
 					{
 						Randomly sample a mini-batch of $\mathcal{M}$ transitions tuples from $\mathcal{R}$\;
 						Update $\beta$ according to Eq. \eqref{eq47}\;
 						Update $\phi$ based on Eq. \eqref{eq48}\;
 						Update ${\psi_1}$ and ${\psi_2}$ based on Eq. \eqref{eq50}\;
 						
 						\If {iteration $r$ can be exactly divided by $R_{t}$ }{
 						Update $\bar \psi_1$ and $\bar \psi_2$ based on Eq. \eqref{eq52}.\;
 					}
 					}

 			}

		}
 	}
\end{algorithm}

Firstly, $\phi$, ${\psi_1}$, ${\psi_2}$ and $\beta$ are  initialized randomly, $\bar \psi_1$ and $\bar \psi_2$ are set to be the same as ${\psi_1}$ and ${\psi_2}$. A replay buffer $\mathcal{R}$ with sufficient space is constructed. The algorithm runs for ${K_{\max }}$ episodes. In the first episode, the mmWave channel coefficient $\zeta$ is initialized based on the Nakagami-$m$ distribution, and the backlog for each queue $i$ is set to zero. The ${\xi }{i,comm}^{dsrc}(0)$ is initialized to $R ^{dsrc}$ for each task type $i$. Given that $N$ types of tasks evenly share the CPU frequency $f_E$, ${\xi }{i,comp}^{mmw}(0)$, ${\xi }{i,comp}^{dsrc}(0)$, and ${\xi }{i,comp}^{cv2i}(0)$ are all set to $\frac{f_{E}}{N \omega_{i}}$. This allows for the computation of ${{\boldsymbol{\xi }_0}}$ as per Eq. \eqref{eq37}.

%The algorithm will conduct ${K_{\max }}$ episodes for training. In the first episode, the mmWave channel coefficient $\zeta$ is initialized according to Nakagami-$m$ distribution. The backlog of each queue $i$ in the VEC server is set to be zero, i.e., $q_{i}(0) = 0 $, ${\xi }_{i,comm}^{dsrc}(0)$ is set to be $R ^{dsrc}$ for each task type $i$. Considering that $N$ types of tasks can equally obtain the CPU frequency $f_E$, thus ${\xi }_{i,comp}^{mmw}(0)$, ${\xi }_{i,comp}^{dsrc}(0)$ and ${\xi }_{i,comp}^{cv2i}(0)$ are all set to $\frac{f_{E}}{N \omega_{i}}$ for each task type $i$. Hence ${{\boldsymbol{\xi }_0}}$ can be obtained according to Eq. \eqref{eq37}.

The algorithm will iteratively be carried out for  $T^{train}_{max}$ time slots. In the first time slot $t=0$, for each task type $i$, $n_{i}$ is generated randomly within time interval $[0,1)$, then ${A_i(0,1)}$ is calculated according to Eq. \eqref{eq2} and thus ${A_i(0)}$ can be obtained. Based on ${A_i(0)}$ and $q_{i}(0)$, ${{\cal Q}_0}$ can be further obtained. Hence, state $s_0$ is obtained according to Eq. \eqref{eq37}. Then, we can input state $s_0$ into the actor network and output the mean ${\mu _\phi }(0)$ and variance $\sum\nolimits_\phi  {(0)}$ of the action distribution, which follows dimensional Gaussian distribution.
Note that to satisfy constraint \eqref{eq32_d}, the dimension of ${\boldsymbol{\alpha}}(0)$ is increased by one, making the action distribution follow a Gaussian distribution with ($4N$+1) dimensions. The action $a_{0}^{\prime}$, comprising of ($N$+1)-dimensional ${\boldsymbol{\alpha}}^{\prime}(0)$ and $3N$-dimensional ${\boldsymbol{\varphi}}^{\prime}(0)$, is sampled based on the action distribution $\pi_\phi(a_{0}|s_{0})$ with mean ${\mu_\phi}(0)$ and variance $\sum_\phi(0)$. A $softmax$ function is applied to ${\boldsymbol{\alpha}}^{\prime}(0)$ and each element of ${\boldsymbol{\varphi}}^{\prime}(0)$ to obtain ${\boldsymbol{\alpha}}(0)$ and ${\boldsymbol{\varphi}}(0)$, ensuring $\sum_{i=1}^{N + 1} \alpha_i(0) = 1$ and $\sum_{g \in G} \varphi_i^g(0) = 1$.
%Note that the dimension of ${\boldsymbol{\alpha}}(0)$ is increased by one to satisfy constraint \eqref{eq32_d}, i.e., $\sum\limits_{i = 1}^N {{\alpha _i}(0) \le 1}$, thus the action distribution follows ($4N$+1)-dimensional Gaussian distribution. Then the action $a_{0}^{\prime}$ is sampled according to the action distribution $\pi _\phi \left( {{a_{0}}|{s_{0}}} \right)$ with the mean ${\mu _\phi }(0)$ and variance $\sum\nolimits_\phi{(0)}$. Here, the action $a_{0}^{\prime}$ includes ($N$+1)-dimensional ${\boldsymbol{\alpha}}^{\prime}(0)$ and $3N$-dimensional ${\boldsymbol{\varphi }}^{\prime}(0)$. A $softmax$ function is adopted for the ($N$+1)-dimensional ${\boldsymbol{\alpha}}^{\prime}(0)$ and each element of ${\boldsymbol{\varphi }}^{\prime}(0)$, we can obtain the ($N$+1)-dimensional ${\boldsymbol{\alpha}}(0)$ and $3N$-dimensional ${\boldsymbol{\varphi }}(0)$, satisfying $\sum\limits_{i = 1}^{N + 1} {{\alpha _i}} \left( 0 \right) = 1$ and $\sum\limits_{g \in G} {\varphi _i^g(0)}  = 1$.
%\begin{equation}
%\sum\limits_{i = 1}^{N + 1} {{\alpha _i}} \left( 0 \right) = 1, \sum\limits_{g \in G} {\varphi _i^g(0)}  = 1
%\label{eq39}.
%\end{equation}
Then ${\boldsymbol{\alpha}}(0)$ is updated as ${{\alpha _i}} \left( t \right)$. As ${{\alpha _{N+1}}}\left( t \right)$ belongs to $[0,1]$, thus  constraint \eqref{eq32_c} $\sum\limits_{i = 1}^N {{\alpha _i}(0) \le 1}$ can be satisfied. Finally, we can obtain action $a_{0}$ based on ${\boldsymbol{\alpha}}(0)$ and ${\boldsymbol{\varphi }}(0)$.
Next, the VEC server takes action $a_0$, and based on this action, the delay upper bound $\omega_i^g(0)$ and reward $r_0$ are calculated using Eq. \eqref{eq28}. Queue $q_i(1)$ is updated per Eq. \eqref{eq3}, and relevant parameters are calculated using Eqs. \eqref{eq12} and \eqref{eq16}, allowing state $s_0$ to transition to $s_1$. The tuple $\left( {{s_0},{a_0},{r_0},{s_1}} \right)$ is stored in the replay buffer, and the process iterates. When time slot $t$ reaches $T^{train}{max}$, the episode number $k$ increments. If $k$ is not divisible by $K_{u}$, the next episode starts; otherwise, the algorithm updates $\beta$ and network parameters $\phi$, ${\psi_1}$, ${\psi_2}$, $\bar \psi_1$, and $\bar \psi_2$ through $R_{u}$ iterations to maximize $J({\pi\left( {{a_t}|{s_t}} \right)})$ as per Eq. \eqref{eq40_1}.
%The detailed update process is given as follows.

%Next, the VEC server will take action $a_0$. Given action $a_0$, the delay upper bound $\omega _i^g(0)$ is calculated according to Eq. \eqref{eq28} and the reward $r_0$ is calculated according to Eq. \eqref{eq28}.
%After $q_i(1)$ is updated for each queue $i$ according to Eq. \eqref{eq3}, and $\beta_{i,comp}(1)$,  ${\xi }_{i,comp}^{mmw}(1)$,  ${\xi }_{i,comp}^{dsrc}(1)$ and  ${\xi }_{i,comp}^{cv2i}(1)$ are calculated according to Eqs. \eqref{eq12} and \eqref{eq16}. Thus, ${{\boldsymbol{\xi }_1}}$ is obtained. The algorithm moves to the next time slot $t=1$ and ${A_i(1)}$ is generated at beginning of time slot $t=1$, and thus ${\cal A}_1$ is obtained and ${{\cal Q}_1}$ is further obtained. Given ${\cal A}_1$, ${{\cal Q}_1}$ and ${{\boldsymbol{\xi }_1}}$, state $s_0$ is transited to $s_1$. The tuple $\left( {{s_0},{a_0},{r_0},{s_1}} \right)$ will be stored in the replay buffer, then the iteration for time slot $0$ is finished, such a process can be iteratively carried out. When time slot $t$ reaches $T^{train}_{max}$, the episode number $k$ is increased by one. If the episode number is not exactly divided by $K_{u}$, the next episode starts. Otherwise, the algorithm will conduct $R_{u}$ iterations to update $\beta$ and the network parameters $\phi$, ${\psi_1}$, ${\psi_2}$, $\bar \psi_1$ and $\bar \psi_2$, to maximize $J({\pi\left( {{a_t}|{s_t}} \right)})$ in Eq. \eqref{eq40_1}. The detailed update process is given as follows.

For each iteration in the update process, $\mathcal{M}$ tuples are randomly selected from the replay buffer to constitute a mini-batch of training data. Let $\left({{s_{m}},{a_{m}},{r_m},{s_{m}^{\prime}}} \right)(m=1,2,\cdots,\mathcal{M})$ be the $m$th tuple in the minibatch. Then, for each tuple $m$, input $s_{m}$ into the actor network and obtain the action $a_{m,new}$ and $log{\pi _\phi }\left( {{a_{m,new}}|{s_m}} \right)$. Then the gradient of the loss function of $\beta$ is calculated as
%\vspace{-0.3cm}
\begin{equation}
{\nabla _{\beta} }J_{m}\left( \beta  \right) = {\nabla _{\beta} }{E}\left[ { - \beta log{\pi _\phi }\left( {{a_{m,new}}|{s_m}} \right) - \beta \overline {\cal H} } \right]
\label{eq47}.
%\vspace{-0.5cm}
\end{equation}

%The parameter of the weight of the policy entropy is update with the gradient, i.e, updating $\beta$ toward the direction of the gradient of $J\left( \beta  \right)$ denoted as ${\nabla _{\beta} }J\left( \beta  \right)$

Then after inputting $s_m$ and $a_{m,new}$ into the two critic networks, respectively, the two critic networks will output the action-value functions ${Q_{{\psi _1}}}\left( {{s_m},{a_{m,new}}} \right)$ and ${Q_{{\psi _2}}}\left( {{s_m},{a_{m,new}}} \right)$, respectively.
The gradient of the loss function of ${\phi}$ can be calculated based on ${Q_{{\psi _1}}}\left( {{s_m},{a_{m,new}}} \right)$ and ${Q_{{\psi _2}}}\left( {{s_m},{a_{m,new}}} \right)$, i.e.,
\begin{equation}
\begin{aligned}
&{ \nabla _\phi }{J_{m} }\left( \phi  \right) = {\nabla _\phi }\beta log\left( {{\pi _\phi }\left( {{a_{m,new}}|{s_m}} \right)} \right) + {\nabla _\phi }f\left( {{\varepsilon };{s_m}} \right) \cdot \\
&   {\nabla _{{a_{m,new}}}}
	\left( \beta log\left( {{\pi _\phi }\left( {{a_{m,new}}|{s_m}} \right)} \right) -  Q\left( {{s_m},{a_{m,new}}} \right)
	\right)
\end{aligned}
\label{eq48},
\end{equation} where $Q(s_m, a_{m,new})$ is calculated as the minimum of $Q_{{\psi_1}}(s_m, a_{m,new})$ and $Q_{{\psi_2}}(s_m, a_{m,new})$.
%\begin{equation}
%\begin{aligned}
%& Q\left( {{s_m},{a_{m,new}}} \right)  = \\ & \qquad \qquad min\left\{ {{Q_{{\psi _1}}}\left( {{s_m},{a_{m,new}}} \right),{Q_{{\psi _2}}}\left( {{s_m},{a_{m,new}}} \right)} \right\},
%\end{aligned}
%\label{eq48_1}
%\end{equation}
${\varepsilon}$ is a noise sampled from multivariate normal distribution and ${f_\phi }\left( {{\varepsilon };{s_m}} \right)$ is a function to reparameterize the action $a_{m,new}$ \cite{2018Haarnoja}.

The algorithm computes the gradients of the loss functions for ${\psi_1}$ and ${\psi_2}$. It inputs $s_m$ and $a_m$ into two critic networks to produce action-value functions ${Q_{{\psi 1}}}(s_m, a_m)$ and ${Q{{\psi 2}}}(s_m, a_m)$. Also, it feeds $s{m}^{\prime}$ into the actor network to obtain $a_{m}^{\prime}$ and $log\pi \phi ^{\prime}(a{m}^{\prime} | s_{m}^{\prime})$. Next, $s_{m}^{\prime}$ and $a_{m}^{\prime}$ are input into two target critic networks, yielding ${Q_{{{\bar \psi }1}}}(s{m}^{\prime}, a_{m}^{\prime})$ and ${Q_{{{\bar \psi }2}}}(s{m}^{\prime}, a_{m}^{\prime})$. The target value is then computed as follows:
%Now, the algorithm will calculate the gradients of the loss functions of ${\psi_1}$ and ${\psi_2}$. Input $s_m$ and $a_m$ into the two critic networks and output action-value functions ${Q_{{\psi _1}}}\left( {{s_m},{a_{m}}} \right)$ and ${Q_{{\psi _2}}}\left( {{s_m},{a_{m}}} \right)$. Additionally, input $s_{m}^{\prime}$ into the actor network and obtain $a_{m}^{\prime}$ and $log\pi _\phi ^{\prime}\left( {{a_{m}^{\prime}}|{s_{m}^{\prime}}} \right)$ based on the output of the actor network, then input $s_{m}^{\prime}$ and $a_{m}^{\prime}$ into the two target critic networks, which will output ${Q_{{{\bar \psi }_1}}}\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}} \right)$ and ${Q_{{{\bar \psi }_2}}}\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}} \right)$, respectively. Then, we can calculate the target value as follows,
\begin{equation}
\begin{aligned}
& \hat Q\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}}\right) = \\ & - \beta log\pi _\phi ^{\prime}\left( {{a_{m}^{\prime}}|{s_{m}^{\prime}}} \right)+
min\left\{ {{Q_{{{\bar \psi }_1}}}\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}} \right),{Q_{{{\bar \psi }_2}}}({s_{m}^{\prime}},{a_{m}^{\prime}})} \right\}
\end{aligned}.
\label{eq49}
\end{equation}
The gradients of the loss functions of ${\psi_1}$ and ${\psi_2}$ are calculated as
\begin{equation}
\begin{aligned}
	&{\nabla _{{\psi _i}}}{J_{m}}\left( {{\psi _i}} \right)  = {\nabla _{{\psi _i}}}{Q_{{\psi _i}}}\left( {{s_m},{a_m}} \right) \cdot \\
	& \quad \left( {{Q_{{\psi _i}}}\left( {{s_m},{a_m}} \right) - {r_m} + \gamma \hat Q\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}} \right)} \right), i\in \left\{ 1,2\right\}
\end{aligned}.
	\label{eq50}
\end{equation}
%\begin{equation}
%\begin{aligned}
%	{ \nabla _{{\psi _2}}}{J_{m}}\left( {{\psi _2}} \right) & = {\nabla _{{\psi _2}}}{Q_{{\psi _2}}}\left( {{s_m},{a_m}} \right) \\
%	& \left( {{Q_{{\psi_2}}}\left( {{s_m},{a_m}} \right) - {r_m} + \gamma \hat Q\left( {{s_{m}^{\prime}},{a_{m}^{\prime}}} \right)} \right)
%\end{aligned}.
%\label{eq51}
%\end{equation}

The Adam optimizer is adopted to update $\beta$, $\phi$, ${\psi_1}$ and ${\psi_2}$ through gradient ascending based on ${\nabla _{\beta} }J_m\left( \beta_{t}  \right)$, ${ \nabla _\phi }{J_{m} }\left( \phi  \right)$, ${ \nabla _{{\psi _1}}}{J_{m}}\left( {{\psi _1}} \right)$ and ${ \nabla _{{\psi _2}}}{J_{m}}\left( {{\psi _2}} \right)$. After every $R_t$ iterations, the parameters of the two target critic network are updated as
\begin{equation}
	{\bar \psi _i}: = \tau_{i} {\psi _i} + \left( {i - \tau_{i} } \right){\bar \psi _i}, i\in \left\{ 1,2\right\}
	\label{eq52}.
\end{equation} where $\tau_{1}$ and $\tau_{2}$ are constants satisfying $\tau_{1}  \ll 1$ and $\tau_{2}  \ll 1$.
%
%
%\begin{equation}
%{\bar \psi _2}: = \tau_{2} {\psi _2} + \left( {1 - \tau_{2} } \right){\bar \psi _2}
%\label{eq53},
%\end{equation} where $\tau_{1}$ and $\tau_{2}$ are constants satisfying $\tau_{1}  \ll 1$ and $\tau_{2}  \ll 1$.

