\section{Derivation of the Tractable Upper Bound}
%\vspace{-0.2cm}
%	\subsection{Low Latency Constraint}
	
According to concatenation theorem in SNC, the two services constitute a tandem service\cite{ref33}, $S_i^g(s ,t+\omega _i^g(t))$ is calculated as $\left( {\beta _{i,comm}^g \otimes \beta _{i,comp}^g} \right)({s ,t + \omega _i^g(t)})$,
%\begin{equation}
%S_i^g\left( {s ,t + \omega _i^g(t)} \right) = \left( {\beta _{i,comm}^g \otimes \beta _{i,comp}^g} \right)({s ,t + \omega _i^g(t)}),
%\label{eq18}
%\end{equation}
where $\otimes$ is the mini-plus convolution operator\cite{2001Le},
%According to the mini-plus deconvolution operation and the mini-plus convolution operation rule\cite{2001Le}, we have
\begin{equation}
\begin{aligned}
& \left( {\beta _{i,comm}^g \otimes \beta _{i,comp}^g} \right)\left( {s ,t + \omega _i^g(t)} \right)   = \\ & \qquad \mathop {\inf }\limits_{s \le z \le t+\omega _i^g(t)} \left\{ {\beta _{i,comm}^g\left( {s,z } \right) + \beta _{i,comp}^g\left( {z,t+\omega _i^g(t)} \right)} \right\}.
\end{aligned}
\label{eq19}
\end{equation}
	
Using union bound and Boole's inequality for Eq. \eqref{eq22},
	\begin{equation}
	\begin{aligned}
	& P(A_i \oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0)=
	 \\ & P\left\{ {\mathop {\sup }\limits_{0 \le s \le u^{\prime}} \left[ {A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)} \right] \ge 0} \right\}\\
	& = P\left\{ {\bigcup\limits_{s = 0}^{u^{\prime}} \left\{A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)\right\}  \ge 0} \right\} \\
	& \le \sum\limits_{s = 0}^{u^{\prime}} {P\left\{ \left\{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right) \right\} \ge 0 \right\}} \\
	& \le \sum\limits_{s = 0}^{{u^\prime }} {E[{e^{\theta \{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)\} }}]} \\
	& = \sum\limits_{s = 0}^{{u^\prime }} E[e^{\theta A_i\left( {s,t} \right)}] E[e^{-\theta S_i^g\left( {s,t + \omega _i^g(t)} \right)}]
	%&\le \sum\limits_{s = 0}^{u^{\prime}} {P\left\{ \left\{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right) \right\} \ge 0 \right\}}
	\end{aligned}.
	\label{eq22_0}
	\end{equation}
%	By applying the Boole's inequality, Eq. \eqref{eq22_0} can be further derived as follows,
%	\begin{equation}
%	\begin{small}
%	\begin{aligned}
%	%P(A_i &\oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0) \\
%	%& = P\left\{ {\mathop {\sup }\limits_{0 \le s \le u^{\prime}} \left[ {A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)} \right] \ge 0} \right\}\\
%	P\left\{ {\bigcup\limits_{s = 0}^{u^{\prime}} \left\{A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)\right\}  \ge 0} \right\}
%	& \le \sum\limits_{s = 0}^{u^{\prime}} {P\left\{ \left\{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right) \right\} \ge 0 \right\}}
%	\end{aligned}.
%	\end{small}
%	\label{eq22_01}
%	\end{equation}
%	According to the Chernoff's bound \cite{2006Filder}, Eq. \eqref{eq22_0} is upper bounded to
%	\begin{equation}
%	\begin{aligned}
%	\sum\limits_{s = 0}^{u^{\prime}}  P \left\{\left\{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right) \right\} \ge 0 \right\}
%	& \le \sum\limits_{s = 0}^{{u^\prime }} {E[{e^{\theta \{ A_i\left( {s,t} \right) - S_i^g\left( {s,t + \omega _i^g(t)} \right)\} }}]} \\
%	& = \sum\limits_{s = 0}^{{u^\prime }} E[e^{\theta A_i\left( {s,t} \right)}] E[e^{-\theta S_i^g\left( {s,t + \omega _i^g(t)} \right)}]
%	%& = \sum\limits_{s = 0}^{{u^\prime }} E[e^{\theta A_i\left( {s,t} \right)}] E[e^{-\theta S_i^g\left( {s,t + \omega _i^g(t)} \right)}]
%	\end{aligned},
%	\label{eq22_1}
%	\end{equation}
The first equation holds by using the notion of the $\oslash$
\begin{equation}
\begin{aligned}
 & \left( {A_i \oslash S_i^g} \right)\left( t + \omega _i^g(t),t \right) = \\ & \qquad \qquad \qquad  \mathop {\sup }\limits_{0 \le s \le u^{\prime}} \left\{ {A_i\left( {s ,t} \right) - S_i^g\left( {s ,t+\omega _i^g(t)} \right)} \right\}.
\end{aligned}
\label{eq21}
\end{equation}
The second equation holds by using Chernoff's bound \cite{2006Filder}, and the third equation holds by assuming $A_i\left( {s,t} \right)$ and $S_i^g\left( {s,t + \omega _i^g(t)} \right)$ are independent. $\overline M_{S_i^g}(\theta,s,t + \omega _i^g(t))=M_{S_i^g}(-\theta,s,t + \omega _i^g(t))=E[e^{-\theta S_i^g\left( {s,t + \omega _i^g(t)} \right)}]$ is the moment generation function (MGF) of the $-S_i^g\left( {s,t + \omega _i^g(t)} \right)$. According to the MGF of $\otimes$ lemma\cite{2006Filder},
	\begin{equation}
	\begin{aligned}
	& \overline M_{S_i^g}(\theta,s,t + \omega _i^g(t)) \\ & \le \sum\limits_{z = s}^{t + \omega _i^g(t)} \overline M_{\beta _{i,comm}^g}(\theta,s,z) \overline M_{\beta _{i,comp}^g}(\theta,z,t + \omega _i^g(t))
	\label{eq22_2}
	\end{aligned},
	\end{equation}
	where $\overline M_{\beta _{i,comm}^g}(\theta,s,z) = E[e^{-\theta \beta _{i,comm}^g(s,z)}]$, $\overline M_{\beta _{i,comp}^g}(\theta,z,t + \omega _i^g(t))= E[e^{-\theta \beta _{i,comp}^g(z,t + \omega _i^g(t)) }]$, thus Eq. \eqref{eq22_0} can be upper bounded as
\vspace{-0.3cm}
	\begin{equation}
	\begin{aligned}
	& P(A_i \oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0)  \le \sum\limits_{s = 0}^{{u^\prime }}  E[e^{\theta A_i\left( {s,t} \right)}] \cdot \\ & \qquad\sum\limits_{z = s}^{t + \omega _i^g(t)} E[e^{-\theta \beta _{i,comm}^g(s,z)}] E[e^{-\theta \beta _{i,comp}^g(z,t + \omega _i^g(t)) }]
%	
%	
%	&\overline M_{S_i^g}(\theta,s,t + \omega _i^g(t)) \\ &\quad \le \sum\limits_{z = s}^{t + \omega _i^g(t)} E[e^{-\theta \beta _{i,comm}^g(s,z)}] E[e^{-\theta \beta _{i,comp}^g(z,t + \omega _i^g(t)) }]
	\label{eq22_23}
	\end{aligned}.
	\end{equation} \cite{chang2000performance} define an MFG of the affine envelope model for $t \geq s \geq 0$ as $M_{A_i}(\theta,s,t) = E[{e^{\theta {A_i}\left( {s,t} \right)}}] \le {{e^{\theta {\rho _i}(t - s) + \theta {\sigma _i}}}} $. According to Eqs. \eqref{eq8}, \eqref{eq11} and \eqref{eq152}, $\beta _{i,comm}^g(s,z)$ and  $\beta _{i,comp}^g(z,t + \omega _i^g(t))$ are both calculated by linear functions about $\rho_{i}$ and $\sigma_{i}$, thus similar with ${E[{e^{\theta {A_i}\left( {s,t} \right)}}]}$, we have $	{E[{e^{ - \theta \beta _{i,comm}^g(s,z)}}]}  \le e^{\theta \beta _{i,comp}^g(s,z)}$ and ${E[{e^{ - \theta \beta _i^g(z,t + \omega _{i,comp}^g(t))}}]} \le e^{\theta \beta _{i,comp}^g(z,t + \omega _i^g(t))}$. Thus Eq. \eqref{eq22_23} can further be upper bounded as
\vspace{-0.3cm}
\begin{equation}
\begin{aligned}
& P(A_i \oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0) \le \sum\limits_{s = 0}^{{u^\prime }} {{e^{\theta {A_i}\left( {s,t} \right)}}}  \cdot \\  & \qquad \qquad \sum\limits_{z = s}^{t + \omega _i^g(t)} {{e^{ - \theta \beta _{i,comm}^g(s,z)}}} {e^{ - \theta \beta _{i,comp}^g(z,t + \omega _i^g(t))}}
\end{aligned}.
\label{appendx_eq4}
\end{equation}
Since the interval time $[s_{1},s_{2})$ is relatively small, ${\varphi _j^{g}(t)}$ in time interval $[s_{1},s_{2})$ can be deemed as a constant, thus the service of network and computing provided for the competitive tasks in Eqs.\eqref{eq8} and \eqref{eq11} can be approximated as $\sum\limits_{j \ne i}^N  {\varphi _j^{g}(t)} a_{j}(s_1,s_2)$ and in Eq. \eqref{eq151} is approximated as $ \sum_{\mathcal{G}/{\rm{g}}} \varphi _i^{g}(t) \left[ \rho_{i} (s_{2}-s_{1})  +\sigma_{i} \right]$ repectively, and the computing service of the server provide can be $\beta _{i,{comp}}(s_{1},s_{2}) = \frac{{{f_E}{\alpha _i(t)}}}{{{\omega _i}}}(s_{2}-s_{1})$, thus the computing service of communication technology $g$ provided for the $i$th type of tasks is approximated as
\begin{equation}
\begin{aligned}
& \beta _{i,comp}^g\left( {s_{1},s_{2}} \right) = [\frac{{{f_E}{\alpha _i(t)}}}{{{\omega _i}}} -\sum\nolimits_{\mathcal{G}/{\rm{g}}} {\varphi _i^g(t)} {\rho _i}](s_{2}-s_{1})  -\\ & \qquad \qquad \qquad  \sum\nolimits_{\mathcal{G}/{\rm{g}}}{\varphi _i^g(t)} {\sigma _i}
\end{aligned}.
\label{eq16}
\end{equation} Let $\xi _{i,comp}^{g}(t) = \frac{{{f_E}{\alpha _i(t)}}}{{{\omega _i}}}-\sum\nolimits_{\mathcal{G}/{\rm{g}}} {\varphi _i^g(t)} {\rho _i}$ and $\eta _{i,comp}^{g}(t) =\sum\nolimits_{\mathcal{G}/{\rm{g}}} {\varphi _i^g(t)} {\sigma _i}$,  the network service and computing service  can be expressed as a same form, i.e., $\beta _{i,{serve}}^g(s_{1},s_{2}) = \xi _{i,{serve}}^g(t)(s_{2}-s_{1}) - \eta _{i,{serve}}^g(t)$, where $serve \in \{comm,comp\}$ and $g \in \mathcal{G} = \left\{mmw,dsrc,cv2i\right\}$. To perform a geometric series summation on the second term of Eq. \eqref{appendx_eq4}, then we have
%Eq. \eqref{appendx_eq4} can be as
%\vspace{-0.3cm}
\begin{equation}
\begin{aligned}
&P(A_i \oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0)   \le
%{e^{\theta   {\Delta _1}}} \cdot \\ & \sum\limits_{s = 0}^{{u^\prime }} {{e^{ - \theta s({\rho _i} - \xi _{i,{comm}}^g(t))}}} \sum\limits_{z = s}^{t + \omega _i^g(t)} {{e^{ - \theta z(\xi _{i,{comm}}^g(t) - \xi _{i,{comp}}^g(t))}}}
\\ &  {e^{\theta   {\Delta _2}}}\sum\limits_{s = 0}^{{u^\prime }} {{e^{\theta (t + \omega _i^g(t) - s)({\rho _i} -\xi _{i,{comp}}^g(t))}}} \cdot
\\ & \qquad \qquad \sum\limits_{{z^\prime } = 0}^{t + \omega _i^g(t) - s} {{e^{ - \theta {z^\prime }(\xi _{i,{comm}}^g(t) - \xi _{i,{comp}}^g(t))}}}
\end{aligned}.
\label{appendx_eq5}
\end{equation} where $\Delta _2 =-{\rho _i}\omega _i^g(t) + {\sigma _i} + \eta _{i,comm}^{g}(t) + \eta _{i,comp}^{g}(t)$.
%The first equation holds by extracting variables that are unrelated to $z$ and $s$ out, i.e., $\Delta _1 = {\rho _i}t  + {\sigma _i} + \eta _{i,comm}^{g}(t)+ \eta _{i,comp}^{g}(t) - \xi _{i,{comp}}^g(t)(t + \omega _i^g(t))$.
%The second equation follows by summing the series over $\sum\limits_{z = s}^{t + \omega _i^g(t)} {{e^{ - \theta z(\xi _{i,{comm}}^g(t) - \xi _{i,{comp}}^g(t))}}}$
%, where $\Delta _2 =-{\rho _i}\omega _i^g(t) + {\sigma _i} + \eta _{i,comm}^{g}(t) + \eta _{i,comp}^{g}(t)$.

Let ${s^\prime} = t + \omega _i^g(t) - s $ and $\tau_{0}  = \max \{ 0,\omega _i^g(t)\}$. Since $0 \le s \le {u^\prime }$ and $u^\prime = \min \{ t + \omega _i^g(t),t\}$, we have ${s^\prime} \in [\tau_{0} ,t + \omega _i^g(t)]$, Eq. \eqref{appendx_eq5} can be written as	
\begin{equation}
	\begin{aligned}
& P(A_i \oslash S_i^g ( {t + {\omega _i^g(t)},t}) \ge 0) \le  {e^{\theta  \cdot {\Delta _2}}} \cdot \\ & \sum\limits_{{s^\prime} = \tau_{0} }^{t + \omega _i^g(t)} {{e^{\theta ({s^\prime})({\rho _i} - \xi _{i,{comp}}^g(t))}}} \sum\limits_{{z^\prime } = 0}^{{s^\prime}} {{e^{ - \theta {z^\prime }(\xi _{i,{comm}}^g(t)- \xi _{i,{comp}}^g(t))}}}
\end{aligned}.
\label{appendx_eq9}
\end{equation}
After performing a geometric scaling on third term in Eq. \eqref{appendx_eq9}, then
%Similarly, we calculate $\sum\limits_{{z^\prime } = 0}^{{s^\prime}} {{e^{ - \theta {z^\prime }(\xi _{i,{comm}}^g-\xi _{i,{comp}}^g)}}}$ in Eq. \eqref{appendx_eq9} based on the isoperimetric series,
