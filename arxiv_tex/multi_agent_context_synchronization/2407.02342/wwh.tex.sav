\\ & \qquad \qquad \frac{{{e^{\theta  \cdot {\Delta}}}}}{{{e^{ - \theta \xi _{i,{comp}}^g(t)}} - {e^{ - \theta \xi _{i,{comm}}^g(t)}}}} \cdot
\\& \qquad \qquad  \{ \frac{{{e^{ - \theta \xi _{i,{comp}}^g(t)\omega _i^g(t)}}}}{{{e^{\theta \xi _{i,{comp}}^g(t)}} - {e^{\theta {\rho _i}}}}} -\frac{{{e^{ - \theta \xi _{i,{comm}}^g(t)\omega _i^g(t)}}}}{{{e^{\theta \xi _{i,{comm}}^g(t)}} - {e^{\theta {\rho _i}}}}}\}
\end{aligned}.
\label{appendx_eq11}
