@misc{jiang_s3_2025,
	title = {s3: {You} {Don}'t {Need} {That} {Much} {Data} to {Train} a {Search} {Agent} via {RL}},
	shorttitle = {s3},
	url = {http://arxiv.org/abs/2505.14146},
	doi = {10.48550/arXiv.2505.14146},
	abstract = {Retrieval-augmented generation (RAG) systems empower large language models (LLMs) to access external knowledge during inference. Recent advances have enabled LLMs to act as search agents via reinforcement learning (RL), improving information acquisition through multi-turn interactions with retrieval engines. However, existing approaches either optimize retrieval using search-only metrics (e.g., NDCG) that ignore downstream utility or fine-tune the entire LLM to jointly reason and retrieve-entangling retrieval with generation and limiting the real search utility and compatibility with frozen or proprietary models. In this work, we propose s3, a lightweight, model-agnostic framework that decouples the searcher from the generator and trains the searcher using a Gain Beyond RAG reward: the improvement in generation accuracy over naive RAG. s3 requires only 2.4k training samples to outperform baselines trained on over 70x more data, consistently delivering stronger downstream performance across six general QA and five medical QA benchmarks.},
	urldate = {2025-08-06},
	publisher = {arXiv},
	author = {Jiang, Pengcheng and Xu, Xueqiang and Lin, Jiacheng and Xiao, Jinfeng and Wang, Zifeng and Sun, Jimeng and Han, Jiawei},
	month = may,
	year = {2025},
	note = {arXiv:2505.14146 [cs]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	file = {Full Text PDF:/Users/hongtingtsang/Zotero/storage/DAG43JUW/Jiang et al. - 2025 - s3 You Don't Need That Much Data to Train a Search Agent via RL.pdf:application/pdf;Snapshot:/Users/hongtingtsang/Zotero/storage/BWD939WW/2505.html:text/html},
}

@misc{bai_autoschemakg_2025,
	title = {{AutoSchemaKG}: {Autonomous} {Knowledge} {Graph} {Construction} through {Dynamic} {Schema} {Induction} from {Web}-{Scale} {Corpora}},
	shorttitle = {{AutoSchemaKG}},
	url = {http://arxiv.org/abs/2505.23628},
	doi = {10.48550/arXiv.2505.23628},
	abstract = {We present AutoSchemaKG, a framework for fully autonomous knowledge graph construction that eliminates the need for predefined schemas. Our system leverages large language models to simultaneously extract knowledge triples and induce comprehensive schemas directly from text, modeling both entities and events while employing conceptualization to organize instances into semantic categories. Processing over 50 million documents, we construct ATLAS (Automated Triple Linking And Schema induction), a family of knowledge graphs with 900+ million nodes and 5.9 billion edges. This approach outperforms state-of-the-art baselines on multi-hop QA tasks and enhances LLM factuality. Notably, our schema induction achieves 92{\textbackslash}\% semantic alignment with human-crafted schemas with zero manual intervention, demonstrating that billion-scale knowledge graphs with dynamically induced schemas can effectively complement parametric knowledge in large language models.},
	urldate = {2025-08-06},
	publisher = {arXiv},
	author = {Bai, Jiaxin and Fan, Wei and Hu, Qi and Zong, Qing and Li, Chunyang and Tsang, Hong Ting and Luo, Hongyu and Yim, Yauwai and Huang, Haoyu and Zhou, Xiao and Qin, Feng and Zheng, Tianshi and Peng, Xi and Yao, Xin and Yang, Huiwen and Wu, Leijie and Ji, Yi and Zhang, Gong and Chen, Renhai and Song, Yangqiu},
	month = aug,
	year = {2025},
