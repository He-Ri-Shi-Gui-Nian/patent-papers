	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	annote = {Comment: submitted to ARR May},
	file = {Full Text PDF:/Users/hongtingtsang/Zotero/storage/EV7AMFP7/Li et al. - 2025 - Towards Agentic RAG with Deep Reasoning A Survey of RAG-Reasoning Systems in LLMs.pdf:application/pdf;Snapshot:/Users/hongtingtsang/Zotero/storage/N6J8USKY/2507.html:text/html},
