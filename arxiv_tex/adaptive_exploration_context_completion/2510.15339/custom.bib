	keywords = {Computer Science - Information Retrieval},
	file = {Full Text PDF:/Users/hongtingtsang/Zotero/storage/FFBYKKLE/Han et al. - 2025 - RAG vs. GraphRAG A Systematic Evaluation and Key Insights.pdf:application/pdf;Snapshot:/Users/hongtingtsang/Zotero/storage/8WJPVXNL/2502.html:text/html},
}

@misc{li_structrag_2024,
	title = {{StructRAG}: {Boosting} {Knowledge} {Intensive} {Reasoning} of {LLMs} via {Inference}-time {Hybrid} {Information} {Structurization}},
