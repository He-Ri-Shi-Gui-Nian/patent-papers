	annote = {Comment: Accepted by COLING 2020},
	file = {Full Text PDF:/Users/hongtingtsang/Zotero/storage/WAMIGM93/Ho et al. - 2020 - Constructing A Multi-hop QA Dataset for Comprehensive Evaluation of Reasoning Steps.pdf:application/pdf;Snapshot:/Users/hongtingtsang/Zotero/storage/NSFGRL7K/2011.html:text/html},
}

@article{kwiatkowski_natural_2019,
