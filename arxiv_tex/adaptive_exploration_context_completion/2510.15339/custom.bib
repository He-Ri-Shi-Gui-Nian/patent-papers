	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	file = {Full Text PDF:/Users/hongtingtsang/Zotero/storage/JHHHIZ85/Huang et al. - 2025 - Can LLMs be Good Graph Judge for Knowledge Graph Construction.pdf:application/pdf;Snapshot:/Users/hongtingtsang/Zotero/storage/RCHBYG7B/2411.html:text/html},
}

