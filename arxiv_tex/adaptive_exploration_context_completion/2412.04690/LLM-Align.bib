	month = jul,
	pages = {1452--1461},
	publisher = {Association for Computational Linguistics},
	title = {Multi-Channel Graph Neural Network for Entity Alignment},
	url = {https://aclanthology.org/P19-1140},
	year = {2019},
	bdsk-url-1 = {https://aclanthology.org/P19-1140},
