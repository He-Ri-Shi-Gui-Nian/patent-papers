\usepackage[ruled,vlined]{algorithm2e}
\SetFuncSty{textsc}   % no backslash

% Tidy caption + spacing
\SetAlCapFnt{\small}
\SetAlCapNameFnt{\small}
\SetAlCapSkip{0.5em}
\SetAlgoInsideSkip{smallskip}
\DontPrintSemicolon
% Nice I/O keys
\SetKwInput{KwIn}{Input}
\SetKwInput{KwOut}{Output}
% Function names used below
\SetKwFunction{Get}{get\_all\_neighbours}
\SetKwFunction{Construct}{construct\_sparql\_query}
\SetKwFunction{Execute}{execute\_sparql\_query}
\SetKwFunction{Extract}{extract\_unique\_properties}
\SetKwFunction{Format}{format\_as\_table}
% Optional: inline comment marker
\SetKwComment{Comment}{$\triangleright$ }{}






