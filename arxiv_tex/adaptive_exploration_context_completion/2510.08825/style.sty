\ProvidesPackage{style}

\usepackage[skins,breakable,listings]{tcolorbox}

% Colors
\definecolor{codebackground}{RGB}{248,248,248}
\definecolor{codeborder}{RGB}{204,204,204}
\definecolor{sparqlblue}{RGB}{0,0,139}
\definecolor{sparqlgreen}{RGB}{0,128,0}
\definecolor{sparqlred}{RGB}{139,0,0}





% SPARQL language for listings
\lstdefinelanguage{SPARQL}{
  morekeywords={
    PREFIX,BASE,SELECT,DISTINCT,WHERE,FILTER,OPTIONAL,BIND,UNION,VALUES,
    ORDER,BY,LIMIT,OFFSET,ASK,CONSTRUCT,DESCRIBE,FROM,NAMED,GRAPH
  },
  sensitive=true,
  morestring=[b]",     % " ... "
  morestring=[b]',     % ' ... '
  morecomment=[l]{\#}  % # line comments
}




% Boxed SPARQL environment (no caption/title)
\newtcblisting{sparqlcode}{
  listing only,
  colback=codebackground,
  colframe=codeborder,
  arc=3mm,
  boxrule=0.5pt,
  top=0mm,
  bottom=0mm,
  left=3mm,
  right=1mm,
  enhanced,
  breakable,
  listing options={
    language=SPARQL,
    basicstyle=\fontsize{8.7}{10.6}\selectfont\ttfamily,
    keywordstyle=\color{sparqlblue}\bfseries,
    stringstyle=\color{sparqlred},
    commentstyle=\color{sparqlgreen},
    breaklines=true,
    postbreak=\mbox{\textcolor{sparqlred}{$\hookrightarrow$}\space},
    showstringspaces=false,
    columns=fullflexible
  }
}









