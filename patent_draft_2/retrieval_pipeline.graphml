<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphstruct.org/xmlns">
  <graph id="RetrievalPipeline" edgedefault="directed">
    <!-- Input -->
    <node id="query" label="用户查询q"/>
    
    <!-- Entity Extraction -->
    <node id="llm_extract" label="LLM提取:法律文件+要件本体对"/>
    
    <!-- Path 1: Structured Retrieval -->
    <node id="path1_candidates" label="候选节点集合1"/>
    <node id="law_chunks" label="法律文件连接的内容切片"/>
    <node id="req_chunks" label="要件本体连接的内容切片"/>
    <node id="hybrid_retrieval" label="稠密+稀疏混合检索"/>
    <node id="path1_topk" label="路径1 top-k"/>
    
    <!-- Path 2: Semantic Retrieval -->
    <node id="query_rewrite" label="LLM多版本改写"/>
    <node id="queries" label="(q, q1, ..., qm)"/>
    <node id="dense_retrieval" label="逐个稠密检索"/>
    <node id="multiple_topk" label="(m+1)个top-k"/>
    <node id="cross_encoder" label="Cross Encoder重排序"/>
    <node id="rrf_fusion" label="RRF融合"/>
    <node id="path2_topk" label="路径2 top-k"/>
    
    <!-- Merge -->
    <node id="merge" label="合并去重"/>
    <node id="n_nodes" label="n个节点(n≤2k)"/>
    
    <!-- Agent Exploration -->
    <node id="create_agents" label="创建n个检索Agent"/>
    <node id="time_applicability" label="时间适用性判断"/>
    <node id="reset_node" label="重设出发节点"/>
    <node id="context_completion" label="上下文补全计划"/>
    <node id="execute_tools" label="执行Tool Calls"/>
    <node id="check_completion" label="完成?"/>
    <node id="agent_results" label="Agent结果"/>
    
    <!-- Meeting Agent -->
    <node id="meeting_host" label="会议主持Agent"/>
    <node id="scope_check" label="范围适用性判断"/>
    <node id="filter_unfit" label="过滤不适用Agent"/>
    <node id="reset_count" label="重置tool call次数"/>
    
    <!-- Audit Agent -->
    <node id="audit_host" label="审计Agent"/>
    <node id="loop_detection" label="兜圈子检测"/>
    <node id="terminate_loop" label="终止循环Agent"/>
    <node id="continue_explore" label="配合继续探索"/>
    
    <!-- Final -->
    <node id="x_evidences" label="x个结构化证据"/>
    <node id="rerank" label="LLM重排序"/>
    <node id="generate_answer" label="生成回答"/>
    
    <!-- Edges -->
    <edge source="query" target="llm_extract"/>
    
    <edge source="llm_extract" target="path1_candidates"/>
    <edge source="path1_candidates" target="law_chunks"/>
    <edge source="path1_candidates" target="req_chunks"/>
    <edge source="law_chunks" target="hybrid_retrieval"/>
    <edge source="req_chunks" target="hybrid_retrieval"/>
    <edge source="hybrid_retrieval" target="path1_topk"/>
    
    <edge source="query" target="query_rewrite"/>
    <edge source="query_rewrite" target="queries"/>
    <edge source="queries" target="dense_retrieval"/>
    <edge source="dense_retrieval" target="multiple_topk"/>
    <edge source="multiple_topk" target="cross_encoder"/>
    <edge source="cross_encoder" target="rrf_fusion"/>
    <edge source="rrf_fusion" target="path2_topk"/>
    
    <edge source="path1_topk" target="merge"/>
    <edge source="path2_topk" target="merge"/>
    <edge source="merge" target="n_nodes"/>
    
    <edge source="n_nodes" target="create_agents"/>
    <edge source="create_agents" target="time_applicability"/>
    <edge source="time_applicability" target="reset_node" label="不适用"/>
    <edge source="time_applicability" target="context_completion" label="适用"/>
    <edge source="reset_node" target="context_completion"/>
    <edge source="context_completion" target="execute_tools"/>
    <edge source="execute_tools" target="check_completion"/>
    <edge source="check_completion" target="execute_tools" label="未完成"/>
    <edge source="check_completion" target="agent_results" label="完成"/>
    
    <edge source="agent_results" target="meeting_host"/>
    <edge source="meeting_host" target="scope_check"/>
    <edge source="scope_check" target="filter_unfit"/>
    <edge source="filter_unfit" target="reset_count"/>
    
    <edge source="reset_count" target="audit_host"/>
    <edge source="audit_host" target="loop_detection"/>
    <edge source="loop_detection" target="terminate_loop" label="兜圈子"/>
    <edge source="loop_detection" target="continue_explore" label="有价值"/>
    
    <edge source="terminate_loop" target="x_evidences"/>
    <edge source="continue_explore" target="x_evidences"/>
    <edge source="x_evidences" target="rerank"/>
    <edge source="rerank" target="generate_answer"/>
  </graph>
</graphml>
