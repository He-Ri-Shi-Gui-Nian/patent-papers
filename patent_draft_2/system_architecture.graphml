<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphstruct.org/xmlns">
  <graph id="SystemArchitecture" edgedefault="directed">
    <!-- Input Layer -->
    <node id="pdf_input" label="PDF法律文件"/>
    <node id="user_query" label="用户查询q"/>
    
    <!-- Document Processing Pipeline -->
    <node id="marker_convert" label="Marker转换"/>
    <node id="markdown_review" label="人工校对Markdown"/>
    <node id="json_struct" label="JSON结构化"/>
    <node id="chunk_agent" label="切片Agent"/>
    <node id="metadata_extract" label="Metadata提取(LLM)"/>
    
    <!-- Graph Construction -->
    <node id="empty_graph" label="空图(地位本体+要件本体)"/>
    <node id="law_node" label="法律性本体节点"/>
    <node id="chunk_nodes" label="内容切片节点"/>
    <node id="graph_connect" label="建立连接关系"/>
    <node id="knowledge_graph" label="知识图谱"/>
    
    <!-- Retrieval Pipeline -->
    <node id="entity_extract" label="实体提取(LLM)"/>
    <node id="dual_path" label="双路召回"/>
    <node id="struct_path" label="路径1:结构化召回"/>
    <node id="semantic_path" label="路径2:语义召回"/>
    <node id="merge_dedup" label="合并去重"/>
    
    <!-- Agent Exploration -->
    <node id="agent_create" label="创建检索Agent"/>
    <node id="time_check" label="时间适用性检查"/>
    <node id="context_plan" label="上下文补全计划"/>
    <node id="tool_calls" label="Tool Call执行"/>
    <node id="agent_output" label="Agent输出"/>
    
    <!-- Quality Control -->
    <node id="meeting_agent" label="会议主持Agent"/>
    <node id="scope_filter" label="范围适用性过滤"/>
    <node id="audit_agent" label="审计Agent"/>
    <node id="loop_detect" label="兜圈子检测"/>
    
    <!-- Final Output -->
    <node id="evidence_collection" label="证据集合"/>
    <node id="llm_generate" label="LLM生成回答"/>
    <node id="final_answer" label="最终回答"/>
    
    <!-- Edges -->
    <edge source="pdf_input" target="marker_convert"/>
    <edge source="marker_convert" target="markdown_review"/>
    <edge source="markdown_review" target="json_struct"/>
    <edge source="json_struct" target="chunk_agent"/>
    <edge source="chunk_agent" target="metadata_extract"/>
    <edge source="metadata_extract" target="law_node"/>
    <edge source="metadata_extract" target="chunk_nodes"/>
    <edge source="empty_graph" target="law_node"/>
    <edge source="empty_graph" target="chunk_nodes"/>
    <edge source="law_node" target="graph_connect"/>
    <edge source="chunk_nodes" target="graph_connect"/>
    <edge source="graph_connect" target="knowledge_graph"/>
    
    <edge source="user_query" target="entity_extract"/>
    <edge source="entity_extract" target="dual_path"/>
    <edge source="dual_path" target="struct_path"/>
    <edge source="dual_path" target="semantic_path"/>
    <edge source="knowledge_graph" target="struct_path"/>
    <edge source="knowledge_graph" target="semantic_path"/>
    <edge source="struct_path" target="merge_dedup"/>
    <edge source="semantic_path" target="merge_dedup"/>
    
    <edge source="merge_dedup" target="agent_create"/>
    <edge source="agent_create" target="time_check"/>
    <edge source="time_check" target="context_plan"/>
    <edge source="context_plan" target="tool_calls"/>
    <edge source="tool_calls" target="agent_output"/>
    
    <edge source="agent_output" target="meeting_agent"/>
    <edge source="meeting_agent" target="scope_filter"/>
    <edge source="scope_filter" target="audit_agent"/>
    <edge source="audit_agent" target="loop_detect"/>
    
    <edge source="loop_detect" target="evidence_collection"/>
    <edge source="evidence_collection" target="llm_generate"/>
    <edge source="llm_generate" target="final_answer"/>
  </graph>
</graphml>
