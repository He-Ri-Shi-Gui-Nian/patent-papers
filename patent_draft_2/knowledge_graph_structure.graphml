<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphstruct.org/xmlns">
  <graph id="KnowledgeGraphStructure" edgedefault="undirected">
    <!-- Pre-existing nodes (empty graph) -->
    <node id="status_ontology" label="地位类本体"/>
    <node id="constitution" label="宪法"/>
    <node id="law" label="法律"/>
    <node id="admin_regulation" label="行政法规"/>
    <node id="local_regulation" label="地方性法规"/>
    <node id="dept_rule" label="部门规章"/>
    <node id="judicial_interpretation" label="司法解释"/>
    
    <node id="requirement_ontology" label="要件类本体"/>
    <node id="regulatory_subject" label="监管主体"/>
    <node id="selfregulatory_subject" label="自律主体"/>
    <node id="business_subject" label="经营主体"/>
    
    <!-- Example: Newly ingested legal document -->
    <node id="securities_law" label="《证券法》"/>
    <node id="chunk_1" label="第1条"/>
    <node id="chunk_2" label="第2条"/>
    <node id="chunk_n" label="第N条"/>
    
    <!-- Example: Specific instances -->
    <node id="csrc" label="证监会"/>
    <node id="broker" label="证券公司"/>
    
    <!-- Edges: Status ontology hierarchy (directed) -->
    <edge source="law" target="constitution" label="不得抵触" directed="true"/>
    <edge source="admin_regulation" target="law" label="不得抵触" directed="true"/>
    <edge source="judicial_interpretation" target="law" label="解释" directed="true"/>
    
    <!-- Edges: Law node to status ontology (undirected) -->
    <edge source="securities_law" target="law" label=""/>
    
    <!-- Edges: Law node to chunks (undirected, with version label) -->
    <edge source="securities_law" target="chunk_1" label="现行版本(自2020年3月1日起)"/>
    <edge source="securities_law" target="chunk_2" label="现行版本(自2020年3月1日起)"/>
    <edge source="securities_law" target="chunk_n" label="现行版本(自2020年3月1日起)"/>
    
    <!-- Edges: Chunks to requirement ontology (undirected, with instance label) -->
    <edge source="chunk_1" target="regulatory_subject" label="证监会"/>
    <edge source="chunk_2" target="business_subject" label="证券公司"/>
    <edge source="chunk_2" target="selfregulatory_subject" label="证券业协会"/>
  </graph>
</graphml>
